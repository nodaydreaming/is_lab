<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
        "-//Apache Software Foundation//DTD Struts Configuration 2.3//EN"
        "http://struts.apache.org/dtds/struts-2.3.dtd">

<struts>
    <!--<constant name="struts.action.excludePattern" value="/ueditor/.*" />-->
    <!-- 上传文件的最大值 -->
    <constant name="struts.multipart.maxSize" value="209715200" />

    <package name="index" extends="struts-default, json-default">
        <action name="index" class="indexAction" method="execute">
        </action>
    </package>

    <package name="user" extends="struts-default, json-default" namespace="/">
        <action name="user_login" class="userAction" method="login">
           <result name="success" type="redirect">/admin/main.html</result>
        </action>
        <action name="user_getLoginUser" class="userAction" method="getLoginUser">
            <result name="login" type="redirect">/login.html</result>
        </action>
        <action name="user_update" class="userAction" method="updateUser">
            <result name="login" type="redirect">/login.html</result>
        </action>
        <action name="user_updatePassword" class="userAction" method="updatePassword">
            <result name="login" type="redirect">/login.html</result>
        </action>
        <action name="user_getAll" class="userAction" method="getAllUsers">
            <result name="login" type="redirect">/login.html</result>
        </action>
        <action name="user_add" class="userAction" method="addUser">
            <result name="login" type="redirect">/login.html</result>
        </action>
        <action name="user_delete" class="userAction" method="deleteUser">
            <result name="login" type="redirect">/login.html</result>
        </action>
    </package>

    <package name="notice" extends="struts-default, json-default">
        <action name="notice_addNotice" class="noticeAction" method="addNotice">
        </action>
    </package>

    <package name="libInfo" extends="struts-default, json-default">
        <action name="info_update" class="cn.hznu.islab.action.LibInfoAction" method="updateInfo">
        </action>
        <action name="getInfo" class="cn.hznu.islab.action.LibInfoAction" method="getInfoContent">
        </action>
    </package>

</struts>