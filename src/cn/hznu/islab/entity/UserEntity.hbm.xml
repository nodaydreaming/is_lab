<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-mapping PUBLIC
    "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
    "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping>

    <class name="cn.hznu.islab.entity.UserEntity" table="user" schema="is_lab">
        <id name="id">
            <column name="id" sql-type="int(11)"/>
            <generator class="native"/>
        </id>
        <property name="photo">
            <column name="photo" sql-type="varchar(255)" not-null="false"/>
        </property>
        <property name="username">
            <column name="username" sql-type="varchar(255)" not-null="true"/>
        </property>
        <property name="password">
            <column name="password" sql-type="varchar(255)" not-null="true"/>
        </property>
        <property name="gender">
            <column name="gender" sql-type="varchar(10)" length="10" not-null="false"/>
        </property>
        <property name="nickname">
            <column name="nickname" sql-type="varchar(255)" not-null="false"/>
        </property>
        <property name="email">
            <column name="email" sql-type="varchar(255)" not-null="false"/>
        </property>
        <property name="telephone">
            <column name="telephone" sql-type="varchar(255)" not-null="true"/>
        </property>
        <property name="status">
            <column name="status" sql-type="int(11)" not-null="true"/>
        </property>
    </class>
</hibernate-mapping>