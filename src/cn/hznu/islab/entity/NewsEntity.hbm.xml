<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-mapping PUBLIC
    "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
    "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping>

    <class name="cn.hznu.islab.entity.NewsEntity" table="news" schema="is_lab">
        <id name="id">
            <column name="id" sql-type="int(11)"/>
            <generator class="native"/>
        </id>
        <property name="title">
            <column name="title" sql-type="varchar(255)" not-null="true"/>
        </property>
        <property name="photo">
            <column name="photo" sql-type="varchar(255)" not-null="false"/>
        </property>
        <property name="date">
            <column name="date" sql-type="datetime" not-null="true"/>
        </property>
        <property name="author">
            <column name="author" sql-type="varchar(255)" not-null="true"/>
        </property>
        <property name="content">
            <column name="content" sql-type="text" not-null="false"/>
        </property>
        <property name="status">
            <column name="status" sql-type="int(11)" not-null="true"/>
        </property>
        <property name="url">
            <column name="url" sql-type="varchar(255)" not-null="false"/>
        </property>
    </class>
</hibernate-mapping>